<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="#1565C0">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Challenge Board"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="#FFD600"
        android:gravity="center"
        android:layout_marginBottom="30dp"/>

    <EditText
        android:id="@+id/teamNameEditText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Team Name"
        android:background="#FFFFFF"
        android:padding="12dp"
        android:layout_marginBottom="16dp"/>

    <EditText
        android:id="@+id/sportEditText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Sport eg: Cricket"
        android:background="#FFFFFF"
        android:padding="12dp"
        android:layout_marginBottom="16dp"/>

    <EditText
        android:id="@+id/challengeDateEditText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Date eg: 20-05-2026"
        android:background="#FFFFFF"
        android:padding="12dp"
        android:layout_marginBottom="24dp"/>

    <Button
        android:id="@+id/postChallengeButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="POST CHALLENGE"
        android:backgroundTint="#FFD600"
        android:textColor="#000000"/>

</LinearLayout>